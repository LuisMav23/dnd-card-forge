# Supabase (required for auth and data)
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
#
# Google OAuth (Supabase): In Google Cloud Console → Credentials → your OAuth 2.0 Web client,
# Authorized redirect URIs must include EXACTLY (replace <project-ref> with yours from the URL above):
#   https://<project-ref>.supabase.co/auth/v1/callback
# If you only list http://localhost:3000/auth/callback in Google, sign-in fails with Error 400: redirect_uri_mismatch.
# Your app's /auth/callback belongs under Supabase Dashboard → Authentication → URL Configuration → Redirect URLs, not in Google.

# Public site URL (no trailing slash). Used for metadata, Open Graph, JSON-LD, and OAuth fallback.
# On Vercel, also add this under Project → Settings → Environment Variables (Production) and redeploy;
# values only in local .env are NOT available during `next build` on Vercel.
# Google OAuth redirect uses /api/auth/oauth-callback-url (request host) so production works even if
# this was missing at build—still set it for metadata. Supabase must list https://YOUR_HOST/auth/callback
# under Authentication → URL Configuration → Redirect URLs, and Site URL = your live origin (not localhost).
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
