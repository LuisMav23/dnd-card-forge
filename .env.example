# Supabase (required for auth and data)
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
#
# Google OAuth (Supabase): In Google Cloud Console → Credentials → your OAuth 2.0 Web client,
# Authorized redirect URIs must include EXACTLY (replace <project-ref> with yours from the URL above):
#   https://<project-ref>.supabase.co/auth/v1/callback
# If you only list http://localhost:3000/auth/callback in Google, sign-in fails with Error 400: redirect_uri_mismatch.
# Your app's /auth/callback belongs under Supabase Dashboard → Authentication → URL Configuration → Redirect URLs, not in Google.

# Public site URL (no trailing slash). Used for metadata, Open Graph, and JSON-LD canonical URLs.
# In production, align with the URL you add under Supabase Auth → URL Configuration → Redirect URLs
# (e.g. https://your-domain.com/auth/callback).
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
